# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
ex_h3o-*.tar

# Precompiled NIF tarballs from `mix elixir_make.precompile`. These
# are built in CI by .github/workflows/release.yml and uploaded to
# GitHub Releases; the local `cache/` dir is only produced by ad hoc
# verification runs.
/cache/

# Temporary files, for example, from tests.
/tmp/

# Rust build artifacts
/native/ex_h3o_nif/target/

# Compiled NIF shared library (rebuilt on every `mix compile`)
/priv/*.so
/priv/native/

# Dialyzer PLT files (machine-specific, regenerated per environment)
/priv/plts/

# Forge Framework injected artifacts (proprietary — do not commit)
/.claude/
/review-prompts/
/.forge-framework-cache/
CLAUDE.md

# Benchmark HTML reports + JSON outputs (regenerated per run)
/bench/output/
